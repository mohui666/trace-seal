import { Button, HorizontalBox, VerticalBox } from "std-widgets.slint";

component MetricTile inherits Rectangle {
    in property <string> label-text;
    in property <string> value-text;

    width: 260px;
    height: 92px;
    background: #16202e;
    border-width: 1px;
    border-color: #2a3443;
    border-radius: 8px;

    VerticalBox {
        padding: 14px;
        spacing: 8px;

        Text {
            text: root.label-text;
            color: #8fb1c9;
            font-size: 14px;
        }

        Text {
            text: root.value-text;
            color: #f4f7fb;
            font-size: 24px;
            font-weight: 700;
        }
    }
}

component SectionLabel inherits Text {
    color: #8fb1c9;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
}

component DetailRow inherits Rectangle {
    in property <string> label-text;
    in property <string> value-text;

    height: 28px;

    HorizontalBox {
        spacing: 10px;

        Text {
            text: root.label-text;
            color: #8fb1c9;
            font-size: 13px;
            width: 120px;
        }

        Text {
            text: root.value-text;
            color: #f4f7fb;
            font-size: 13px;
            wrap: word-wrap;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> title-text: "TraceSeal Slint Read-only Spike";
    in property <string> subtitle-text: "Experimental dashboard-data bridge only / 仅实验用途";
    in property <string> bridge-title-text: "Read-only dashboard-data bridge / 只读 dashboard-data 桥接";
    in property <string> data-source-label: "Data source";
    in property <string> data-source: "mock fallback";
    in property <string> bridge-status-label: "Bridge status";
    in property <string> bridge-status: "mock fallback";
    in property <string> latest-run-label: "Latest run";
    in property <string> latest-status-label: "Latest status";
    in property <string> latest-status: "mock";
    in property <int> event-count: 0;
    in property <int> risk-count: 0;
    in property <string> latest-run: "mock-run-0001";
    in property <string> policy-mode: "mock / read-only";
    in property <string> event-count-label: "Event count";
    in property <string> risk-count-label: "Risk count";
    in property <string> policy-mode-label: "Policy summary";
    in property <string> run-detail-title: "Run detail / 运行详情";
    in property <string> detail-run-id-label: "Run ID";
    in property <string> started-at-label: "Started";
    in property <string> finished-at-label: "Finished";
    in property <string> run-title-label: "Title";
    in property <string> workspace-label: "Workspace";
    in property <string> run-policy-mode-label: "Policy mode";
    in property <string> risk-summary-label: "Risk summary";
    in property <string> started-at: "Unavailable";
    in property <string> finished-at: "Unavailable";
    in property <string> run-title: "Mock run";
    in property <string> workspace: "Unavailable";
    in property <string> run-policy-mode: "mock / read-only";
    in property <string> risk-summary: "Unavailable";
    in property <string> last-error-label: "Last error";
    in property <string> last-error: "none";
    in property <string> boundary-text: "Read-only spike: Electron remains the default desktop. Uses only fixed Python Core dashboard-data commands. No traceseal run, target commands, workspace writes, policy edits, packaging changes, release changes, or Stage 5 promotion.";
    in property <string> load-latest-text: "Load latest";
    in property <string> load-policy-text: "Load policy";
    in property <string> load-run-list-text: "Load run list summary";
    in property <string> toggle-language-text: "English / 中文";

    callback toggle-language();
    callback load-latest();
    callback load-policy();
    callback load-run-list();

    title: root.title-text;
    width: 760px;
    height: 820px;
    background: #101820;

    VerticalBox {
        padding: 24px;
        spacing: 16px;

        // Header
        HorizontalBox {
            spacing: 12px;

            VerticalBox {
                spacing: 6px;

                Text {
                    text: root.title-text;
                    color: #f4f7fb;
                    font-size: 30px;
                    font-weight: 700;
                }

                Text {
                    text: root.subtitle-text;
                    color: #8fb1c9;
                    font-size: 16px;
                }
            }

            Button {
                text: root.toggle-language-text;
                width: 112px;
                height: 36px;
                clicked => {
                    root.toggle-language();
                }
            }
        }

        // Bridge Info Card
        Rectangle {
            height: 96px;
            background: #0f2533;
            border-width: 1px;
            border-color: #29475b;
            border-radius: 8px;

            VerticalBox {
                padding: 14px;
                spacing: 6px;

                Text {
                    text: root.bridge-title-text;
                    color: #f4f7fb;
                    font-size: 18px;
                    font-weight: 700;
                }

                Text {
                    text: "dashboard-data latest / dashboard-data list / dashboard-data policy - read-only / 只读";
                    color: #8fb1c9;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Text {
                    text: root.boundary-text;
                    color: #d6e7ef;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }
        }

        // Action Buttons
        HorizontalBox {
            spacing: 12px;

            Button {
                text: root.load-latest-text;
                width: 148px;
                height: 36px;
                clicked => {
                    root.load-latest();
                }
            }

            Button {
                text: root.load-run-list-text;
                width: 196px;
                height: 36px;
                clicked => {
                    root.load-run-list();
                }
            }

            Button {
                text: root.load-policy-text;
                width: 148px;
                height: 36px;
                clicked => {
                    root.load-policy();
                }
            }
        }

        // Bridge Status Section
        SectionLabel {
            text: "BRIDGE / 桥接";
        }

        HorizontalBox {
            spacing: 12px;

            MetricTile {
                label-text: root.data-source-label;
                value-text: root.data-source;
            }

            MetricTile {
                label-text: root.bridge-status-label;
                value-text: root.bridge-status;
            }
        }

        // Latest Run Section
        SectionLabel {
            text: "LATEST RUN / 最新运行";
        }

        HorizontalBox {
            spacing: 12px;

            MetricTile {
                label-text: root.latest-run-label;
                value-text: root.latest-run;
            }

            MetricTile {
                label-text: root.latest-status-label;
                value-text: root.latest-status;
            }
        }

        // Metrics Section
        SectionLabel {
            text: "METRICS / 指标";
        }

        HorizontalBox {
            spacing: 12px;

            MetricTile {
                label-text: root.event-count-label;
                value-text: "\{root.event-count}";
            }

            MetricTile {
                label-text: root.risk-count-label;
                value-text: "\{root.risk-count}";
            }
        }

        // Run Detail Section
        SectionLabel {
            text: "RUN DETAIL / 运行详情";
        }

        Rectangle {
            height: 260px;
            background: #121d29;
            border-width: 1px;
            border-color: #2a3443;
            border-radius: 8px;

            VerticalBox {
                padding: 14px;
                spacing: 7px;

                Text {
                    text: root.run-detail-title;
                    color: #f4f7fb;
                    font-size: 18px;
                    font-weight: 700;
                }

                DetailRow {
                    label-text: root.detail-run-id-label;
                    value-text: root.latest-run;
                }

                DetailRow {
                    label-text: root.latest-status-label;
                    value-text: root.latest-status;
                }

                DetailRow {
                    label-text: root.started-at-label;
                    value-text: root.started-at;
                }

                DetailRow {
                    label-text: root.finished-at-label;
                    value-text: root.finished-at;
                }

                DetailRow {
                    label-text: root.run-title-label;
                    value-text: root.run-title;
                }

                DetailRow {
                    label-text: root.workspace-label;
                    value-text: root.workspace;
                }

                DetailRow {
                    label-text: root.run-policy-mode-label;
                    value-text: root.run-policy-mode;
                }

                DetailRow {
                    label-text: root.risk-summary-label;
                    value-text: root.risk-summary;
                }
            }
        }

        // Policy Section
        SectionLabel {
            text: "POLICY / 策略";
        }

        HorizontalBox {
            spacing: 12px;

            MetricTile {
                label-text: root.policy-mode-label;
                value-text: root.policy-mode;
            }

            MetricTile {
                label-text: root.last-error-label;
                value-text: root.last-error;
            }
        }
    }
}
