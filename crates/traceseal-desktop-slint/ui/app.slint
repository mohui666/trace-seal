import { Button, HorizontalBox, ScrollView, VerticalBox } from "std-widgets.slint";

export struct RunHistoryRow {
    run-id: string,
    status: string,
    started-at: string,
    event-count: int,
    risk-count: int,
}

export struct PolicyRuleRow {
    rule-id: string,
    decision: string,
}

component MetricTile inherits Rectangle {
    in property <string> label-text;
    in property <string> value-text;

    width: 260px;
    height: 92px;
    background: #16202e;
    border-width: 1px;
    border-color: #2a3443;
    border-radius: 8px;

    VerticalBox {
        padding: 14px;
        spacing: 8px;

        Text {
            text: root.label-text;
            color: #8fb1c9;
            font-size: 14px;
        }

        Text {
            text: root.value-text;
            color: #f4f7fb;
            font-size: 24px;
            font-weight: 700;
        }
    }
}

component HistoryHeaderRow inherits Rectangle {
    in property <string> run-id-label;
    in property <string> status-label;
    in property <string> events-label;
    in property <string> risks-label;
    in property <string> started-label;

    height: 30px;
    background: #16202e;
    border-width: 1px;
    border-color: #2a3443;
    border-radius: 6px;

    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Text {
            text: root.run-id-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 190px;
        }

        Text {
            text: root.status-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 88px;
        }

        Text {
            text: root.events-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 58px;
        }

        Text {
            text: root.risks-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 58px;
        }

        Text {
            text: root.started-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 180px;
        }
    }
}

component HistoryDataRow inherits Rectangle {
    in property <string> run-id;
    in property <string> status;
    in property <string> started-at;
    in property <int> event-count;
    in property <int> risk-count;

    height: 38px;
    background: #101b26;
    border-width: 1px;
    border-color: #253241;
    border-radius: 6px;

    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Text {
            text: root.run-id;
            color: #f4f7fb;
            font-size: 13px;
            width: 190px;
            overflow: elide;
        }

        Text {
            text: root.status;
            color: #f4f7fb;
            font-size: 13px;
            width: 88px;
            overflow: elide;
        }

        Text {
            text: "\{root.event-count}";
            color: #f4f7fb;
            font-size: 13px;
            width: 58px;
        }

        Text {
            text: "\{root.risk-count}";
            color: #f4f7fb;
            font-size: 13px;
            width: 58px;
        }

        Text {
            text: root.started-at;
            color: #f4f7fb;
            font-size: 13px;
            width: 180px;
            overflow: elide;
        }
    }
}

component PolicyRuleHeaderRow inherits Rectangle {
    in property <string> rule-id-label;
    in property <string> decision-label;

    height: 30px;
    background: #16202e;
    border-width: 1px;
    border-color: #2a3443;
    border-radius: 6px;

    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Text {
            text: root.rule-id-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 300px;
        }

        Text {
            text: root.decision-label;
            color: #8fb1c9;
            font-size: 12px;
            font-weight: 700;
            width: 160px;
        }
    }
}

component PolicyRuleDataRow inherits Rectangle {
    in property <string> rule-id;
    in property <string> decision;

    height: 38px;
    background: #101b26;
    border-width: 1px;
    border-color: #253241;
    border-radius: 6px;

    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Text {
            text: root.rule-id;
            color: #f4f7fb;
            font-size: 13px;
            width: 300px;
            overflow: elide;
        }

        Text {
            text: root.decision;
            color: #f4f7fb;
            font-size: 13px;
            width: 160px;
            overflow: elide;
        }
    }
}

component SectionLabel inherits Text {
    color: #8fb1c9;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
}

component DetailRow inherits Rectangle {
    in property <string> label-text;
    in property <string> value-text;

    height: 28px;

    HorizontalBox {
        spacing: 10px;

        Text {
            text: root.label-text;
            color: #8fb1c9;
            font-size: 13px;
            width: 120px;
        }

        Text {
            text: root.value-text;
            color: #f4f7fb;
            font-size: 13px;
            wrap: word-wrap;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> title-text: "TraceSeal Slint Read-only Spike";
    in property <string> subtitle-text: "Experimental dashboard-data bridge only / 仅实验用途";
    in property <string> bridge-title-text: "Read-only dashboard-data bridge / 只读 dashboard-data 桥接";
    in property <string> data-source-label: "Data source";
    in property <string> data-source: "mock fallback";
    in property <string> bridge-status-label: "Bridge status";
    in property <string> bridge-status: "mock fallback";
    in property <string> latest-run-label: "Latest run";
    in property <string> latest-status-label: "Latest status";
    in property <string> latest-status: "mock";
    in property <int> event-count: 0;
    in property <int> risk-count: 0;
    in property <string> latest-run: "mock-run-0001";
    in property <string> policy-mode: "mock / read-only";
    in property <string> event-count-label: "Event count";
    in property <string> risk-count-label: "Risk count";
    in property <string> policy-mode-label: "Policy summary";
    in property <string> run-detail-title: "Run detail / 运行详情";
    in property <string> run-history-title: "Run history / 运行历史";
    in property <string> run-history-empty-text: "No runs found / 未找到运行记录";
    in property <string> run-history-run-id-label: "Run ID";
    in property <string> run-history-status-label: "Status";
    in property <string> run-history-events-label: "Events";
    in property <string> run-history-risks-label: "Risks";
    in property <string> run-history-started-label: "Started";
    in property <[RunHistoryRow]> run-history: [];
    in property <bool> run-history-empty: true;
    in property <string> detail-run-id-label: "Run ID";
    in property <string> started-at-label: "Started";
    in property <string> finished-at-label: "Finished";
    in property <string> run-title-label: "Title";
    in property <string> workspace-label: "Workspace";
    in property <string> run-policy-mode-label: "Policy mode";
    in property <string> risk-summary-label: "Risk summary";
    in property <string> started-at: "Unavailable";
    in property <string> finished-at: "Unavailable";
    in property <string> run-title: "Mock run";
    in property <string> workspace: "Unavailable";
    in property <string> run-policy-mode: "mock / read-only";
    in property <string> risk-summary: "Unavailable";
    in property <string> policy-detail-title: "Policy detail / 策略详情";
    in property <string> policy-detail-mode-label: "Policy mode";
    in property <string> policy-detail-source-label: "Policy source";
    in property <string> policy-detail-rule-count-label: "Rule count";
    in property <string> policy-detail-mode: "Unavailable";
    in property <string> policy-detail-source: "Unavailable";
    in property <int> policy-detail-rule-count: 0;
    in property <string> policy-rules-title: "Rules";
    in property <string> policy-rule-id-label: "Rules";
    in property <string> policy-rule-decision-label: "Decision";
    in property <string> policy-rules-empty-text: "No policy rules found / 未找到策略规则";
    in property <[PolicyRuleRow]> policy-rules: [];
    in property <bool> policy-rules-empty: true;
    in property <string> last-error-label: "Last error";
    in property <string> last-error: "none";
    in property <string> boundary-text: "Read-only spike: Electron remains the default desktop. Uses only fixed Python Core dashboard-data commands. No traceseal run, target commands, workspace writes, policy edits, packaging changes, release changes, or Stage 5 promotion.";
    in property <string> load-latest-text: "Load latest";
    in property <string> load-policy-text: "Load policy";
    in property <string> load-run-list-text: "Load run list summary";
    in property <string> load-demo-text: "Load demo data";
    in property <string> toggle-language-text: "English / 中文";
    in property <bool> is-demo-data: false;
    in property <string> demo-source-text: "Showing demo fixture data";
    in property <bool> is-loading: true;
    in property <bool> has-error: false;
    in property <bool> has-data: false;
    in property <string> loading-message: "Loading dashboard data...";
    in property <string> error-message: "";
    in property <string> status-message: "Loading dashboard data...";

    callback toggle-language();
    callback load-latest();
    callback load-policy();
    callback load-run-list();
    callback load-demo();

    title: root.title-text;
    preferred-width: 760px;
    preferred-height: 720px;
    min-width: 720px;
    min-height: 520px;
    background: #101820;

    VerticalBox {
        padding: 24px;
        spacing: 16px;

        // Header
        HorizontalBox {
            spacing: 12px;

            VerticalBox {
                spacing: 6px;

                Text {
                    text: root.title-text;
                    color: #f4f7fb;
                    font-size: 30px;
                    font-weight: 700;
                }

                Text {
                    text: root.subtitle-text;
                    color: #8fb1c9;
                    font-size: 16px;
                }
            }

            Button {
                text: root.toggle-language-text;
                width: 112px;
                height: 36px;
                clicked => {
                    root.toggle-language();
                }
            }
        }

        // Bridge Info Card
        Rectangle {
            height: 116px;
            background: #0f2533;
            border-width: 1px;
            border-color: #29475b;
            border-radius: 8px;

            VerticalBox {
                padding: 14px;
                spacing: 6px;

                Text {
                    text: root.bridge-title-text;
                    color: #f4f7fb;
                    font-size: 18px;
                    font-weight: 700;
                }

                Text {
                    text: "dashboard-data latest / dashboard-data list / dashboard-data policy - read-only / 只读";
                    color: #8fb1c9;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Text {
                    text: root.boundary-text;
                    color: #d6e7ef;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Text {
                    visible: root.is-demo-data;
                    text: root.demo-source-text;
                    color: #ffd580;
                    font-size: 13px;
                    font-weight: 700;
                    wrap: word-wrap;
                }
            }
        }

        // Action Buttons
        HorizontalBox {
            spacing: 12px;

            Button {
                text: root.load-latest-text;
                width: 148px;
                height: 36px;
                enabled: !root.is-loading;
                clicked => {
                    root.load-latest();
                }
            }

            Button {
                text: root.load-demo-text;
                width: 156px;
                height: 36px;
                enabled: !root.is-loading;
                clicked => {
                    root.load-demo();
                }
            }

            Button {
                text: root.load-run-list-text;
                width: 196px;
                height: 36px;
                enabled: !root.is-loading;
                clicked => {
                    root.load-run-list();
                }
            }

            Button {
                text: root.load-policy-text;
                width: 148px;
                height: 36px;
                enabled: !root.is-loading;
                clicked => {
                    root.load-policy();
                }
            }
        }

        // Loading / loaded / error status
        Rectangle {
            height: 44px;
            visible: root.is-loading || root.has-error || root.has-data;
            background: root.has-error ? #3a1f24 : (root.is-loading ? #182b3a : #17311f);
            border-width: 1px;
            border-color: root.has-error ? #8d3f4c : (root.is-loading ? #315b78 : #2f7045);
            border-radius: 8px;

            Text {
                x: 14px;
                y: 12px;
                width: parent.width - 28px;
                text: root.is-loading ? root.loading-message : (root.has-error ? root.error-message : root.status-message);
                color: #f4f7fb;
                font-size: 14px;
                font-weight: 600;
                wrap: word-wrap;
            }
        }

        // Scrollable dashboard content
        ScrollView {
            vertical-stretch: 1;

            VerticalBox {
                spacing: 16px;

                // Bridge Status Section
                SectionLabel {
                    text: "BRIDGE / 桥接";
                }

                HorizontalBox {
                    spacing: 12px;

                    MetricTile {
                        label-text: root.data-source-label;
                        value-text: root.data-source;
                    }

                    MetricTile {
                        label-text: root.bridge-status-label;
                        value-text: root.bridge-status;
                    }
                }

                // Latest Run Section
                SectionLabel {
                    text: "LATEST RUN / 最新运行";
                }

                HorizontalBox {
                    spacing: 12px;

                    MetricTile {
                        label-text: root.latest-run-label;
                        value-text: root.latest-run;
                    }

                    MetricTile {
                        label-text: root.latest-status-label;
                        value-text: root.latest-status;
                    }
                }

                // Metrics Section
                SectionLabel {
                    text: "METRICS / 指标";
                }

                HorizontalBox {
                    spacing: 12px;

                    MetricTile {
                        label-text: root.event-count-label;
                        value-text: "\{root.event-count}";
                    }

                    MetricTile {
                        label-text: root.risk-count-label;
                        value-text: "\{root.risk-count}";
                    }
                }

                // Run History Section
                SectionLabel {
                    text: "RUN HISTORY / 运行历史";
                }

                Rectangle {
                    height: 112px + ((root.run-history-empty ? 1 : root.run-history.length) * 42px);
                    background: #121d29;
                    border-width: 1px;
                    border-color: #2a3443;
                    border-radius: 8px;

                    VerticalBox {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: root.run-history-title;
                            color: #f4f7fb;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        HistoryHeaderRow {
                            run-id-label: root.run-history-run-id-label;
                            status-label: root.run-history-status-label;
                            events-label: root.run-history-events-label;
                            risks-label: root.run-history-risks-label;
                            started-label: root.run-history-started-label;
                        }

                        Rectangle {
                            visible: root.run-history-empty;
                            height: 38px;
                            background: #101b26;
                            border-width: 1px;
                            border-color: #253241;
                            border-radius: 6px;

                            Text {
                                x: 10px;
                                y: 10px;
                                text: root.run-history-empty-text;
                                color: #8fb1c9;
                                font-size: 13px;
                            }
                        }

                        for run in root.run-history : HistoryDataRow {
                            visible: !root.run-history-empty;
                            run-id: run.run-id;
                            status: run.status;
                            event-count: run.event-count;
                            risk-count: run.risk-count;
                            started-at: run.started-at;
                        }
                    }
                }

                // Run Detail Section
                SectionLabel {
                    text: "RUN DETAIL / 运行详情";
                }

                Rectangle {
                    height: 260px;
                    background: #121d29;
                    border-width: 1px;
                    border-color: #2a3443;
                    border-radius: 8px;

                    VerticalBox {
                        padding: 14px;
                        spacing: 7px;

                        Text {
                            text: root.run-detail-title;
                            color: #f4f7fb;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        DetailRow {
                            label-text: root.detail-run-id-label;
                            value-text: root.latest-run;
                        }

                        DetailRow {
                            label-text: root.latest-status-label;
                            value-text: root.latest-status;
                        }

                        DetailRow {
                            label-text: root.started-at-label;
                            value-text: root.started-at;
                        }

                        DetailRow {
                            label-text: root.finished-at-label;
                            value-text: root.finished-at;
                        }

                        DetailRow {
                            label-text: root.run-title-label;
                            value-text: root.run-title;
                        }

                        DetailRow {
                            label-text: root.workspace-label;
                            value-text: root.workspace;
                        }

                        DetailRow {
                            label-text: root.run-policy-mode-label;
                            value-text: root.run-policy-mode;
                        }

                        DetailRow {
                            label-text: root.risk-summary-label;
                            value-text: root.risk-summary;
                        }
                    }
                }

                // Policy Section
                SectionLabel {
                    text: "POLICY / 策略";
                }

                HorizontalBox {
                    spacing: 12px;

                    MetricTile {
                        label-text: root.policy-mode-label;
                        value-text: root.policy-mode;
                    }

                    MetricTile {
                        label-text: root.last-error-label;
                        value-text: root.last-error;
                    }
                }

                // Policy Detail Section
                SectionLabel {
                    text: "POLICY DETAIL / 策略详情";
                }

                Rectangle {
                    height: 198px + ((root.policy-rules-empty ? 1 : root.policy-rules.length) * 42px);
                    background: #121d29;
                    border-width: 1px;
                    border-color: #2a3443;
                    border-radius: 8px;

                    VerticalBox {
                        padding: 14px;
                        spacing: 8px;

                        Text {
                            text: root.policy-detail-title;
                            color: #f4f7fb;
                            font-size: 18px;
                            font-weight: 700;
                        }

                        DetailRow {
                            label-text: root.policy-detail-mode-label;
                            value-text: root.policy-detail-mode;
                        }

                        DetailRow {
                            label-text: root.policy-detail-source-label;
                            value-text: root.policy-detail-source;
                        }

                        DetailRow {
                            label-text: root.policy-detail-rule-count-label;
                            value-text: "\{root.policy-detail-rule-count}";
                        }

                        Text {
                            text: root.policy-rules-title;
                            color: #8fb1c9;
                            font-size: 13px;
                            font-weight: 700;
                        }

                        PolicyRuleHeaderRow {
                            rule-id-label: root.policy-rule-id-label;
                            decision-label: root.policy-rule-decision-label;
                        }

                        Rectangle {
                            visible: root.policy-rules-empty;
                            height: 38px;
                            background: #101b26;
                            border-width: 1px;
                            border-color: #253241;
                            border-radius: 6px;

                            Text {
                                x: 10px;
                                y: 10px;
                                text: root.policy-rules-empty-text;
                                color: #8fb1c9;
                                font-size: 13px;
                            }
                        }

                        for rule in root.policy-rules : PolicyRuleDataRow {
                            visible: !root.policy-rules-empty;
                            rule-id: rule.rule-id;
                            decision: rule.decision;
                        }
                    }
                }
            }
        }
    }
}
